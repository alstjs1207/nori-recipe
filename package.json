  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": "0.8.13",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "postcss": "8.5.10",
      "react-devtools-core>shell-quote": "1.8.4",

    "material-audit": "tsx scripts/material-audit.ts",
    "test": "tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans-kr": "^0.4.1",
